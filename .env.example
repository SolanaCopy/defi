# GoldBot Close Watcher — Environment Variables
# Copy this to .env and fill in your values

# Arbitrum RPC (WebSocket for real-time events, HTTPS for transactions)
# Get a free WSS endpoint from Alchemy or Infura
ARBITRUM_RPC_WSS=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_HTTPS=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# Admin wallet private key (the wallet that deployed the contract)
ADMIN_PRIVATE_KEY=0x...

# Deployed GoldCopyTrader contract address on Arbitrum
GOLD_COPY_TRADER_ADDRESS=0x...
